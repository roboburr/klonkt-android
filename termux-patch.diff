+                            java.io.InputStream in = getAssets().open("klonkt-bundle.tar.gz");
+                            java.io.FileOutputStream out = new java.io.FileOutputStream(part);
+                            byte[] buf = new byte[65536];
+                            int n;
+                            while ((n = in.read(buf)) > 0) out.write(buf, 0, n);
+                            out.close();
+                            in.close();
+                            part.renameTo(new java.io.File("/data/data/com.termux/files/home/klonkt-bundle.tar.gz"));
