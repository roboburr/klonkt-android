+    // Klonkt: write the start script + login-shell hooks. Idempotent (marker-based),
+    // never silently swallows failures, and works even on a half-finished install.
+    private void ensureKlonktBootstrap() {
+        try {
+            java.io.File home = new java.io.File("/data/data/com.termux/files/home");
+            if (!home.exists()) home.mkdirs();
+            java.io.File start = new java.io.File(home, ".klonkt-start.sh");
+            java.io.FileWriter fw = new java.io.FileWriter(start, false);
+            fw.write("#!/data/data/com.termux/files/usr/bin/bash\n");
+            fw.write("# KLONKT_V3\n");
+            fw.write("command -v flock >/dev/null 2>&1 && { exec 9>\"$HOME/.klonkt.lock\"; flock -n 9 || exit 0; }\n");
+            fw.write("if [ ! -f ~/klonkt-node/package.json ]; then\n");
+            fw.write("  curl -sL \"https://raw.githubusercontent.com/roboburr/klonkt-android/main/app/src/main/assets/setup-termux-klonkt.sh?v=5\" | bash\n");
+            fw.write("fi\n");
+            fw.write("curl -s -o /dev/null --max-time 2 http://localhost:3020 || (cd ~/klonkt-node && npm start > ~/klonkt.log 2>&1 &)\n");
+            fw.write("command -v cloudflared >/dev/null 2>&1 || pkg install -y cloudflared\n");
+            fw.write("if [ -s \"$HOME/.klonkt-tunnel-token\" ]; then GODEBUG=netdns=cgo cloudflared tunnel --no-autoupdate --edge-ip-version 4 run --token \"$(cat \"$HOME/.klonkt-tunnel-token\")\"; else GODEBUG=netdns=cgo cloudflared tunnel --no-autoupdate --edge-ip-version 4 --url http://localhost:3020; fi\n");
+            fw.close();
+            String hook = "[ -f ~/.klonkt-start.sh ] && bash ~/.klonkt-start.sh\n";
+            klonktAppendIfMissing(new java.io.File(home, ".bash_profile"), hook);
+            klonktAppendIfMissing(new java.io.File(home, ".profile"), hook);
+        } catch (Exception e) {
+            android.util.Log.e("Klonkt", "bootstrap write failed", e);
+        }
+    }
+
+    private void klonktAppendIfMissing(java.io.File f, String content) throws java.io.IOException {
+        if (f.exists()) {
+            java.io.BufferedReader r = new java.io.BufferedReader(new java.io.FileReader(f));
+            try {
+                String line;
+                while ((line = r.readLine()) != null) if (line.contains(".klonkt-start.sh")) return;
+            } finally { r.close(); }
+        }
+        java.io.FileWriter w = new java.io.FileWriter(f, true);
+        w.write("\n# KLONKT_V3\n" + content);
+        w.close();
+    }
+
+    // Klonkt: type the start command straight into the shell. Belt-and-braces for
+    // any session that didn't source a profile; the flock in the script makes a
+    // double trigger harmless.
+    private void klonktKickstart() {
+        try {
+            if (mTermuxService == null || mTermuxService.getTermuxSessions().isEmpty()) return;
+            com.termux.terminal.TerminalSession ts = mTermuxService.getTermuxSessions().get(0).getTerminalSession();
+            if (ts != null && ts.isRunning()) ts.write("[ -f ~/.klonkt-start.sh ] && bash ~/.klonkt-start.sh\n");
+        } catch (Exception e) {
+            android.util.Log.e("Klonkt", "kickstart failed", e);
+        }
+    }
+
+    private static final String KLONKT_SPLASH = "<html><head><meta name=\"viewport\" content=\"width=device-width, initial-scale=1\"></head><body style=\"margin:0;background:#0b0d12;color:#f3f1ea;font-family:sans-serif;display:flex;align-items:center;justify-content:center;height:100vh\"><div style=\"text-align:center;padding:24px\"><div style=\"font-size:44px;font-weight:800;color:#e8b04b\">Klonkt</div><div style=\"margin-top:14px;font-size:15px;opacity:.85;line-height:1.5\">Bezig met starten&hellip;<br>De eerste keer kan dit enkele minuten duren.</div></div></body></html>";
+
+    // Klonkt: enter/clear a Cloudflare named-tunnel token. With a token the site
+    // gets the user's own fixed domain; without it, a temporary trycloudflare URL.
+    private void showKlonktTokenDialog() {
+        final java.io.File tokenFile = new java.io.File("/data/data/com.termux/files/home/.klonkt-tunnel-token");
+        String existing = "";
+        try {
+            if (tokenFile.exists()) {
+                java.io.BufferedReader r = new java.io.BufferedReader(new java.io.FileReader(tokenFile));
+                existing = r.readLine();
+                r.close();
+                if (existing == null) existing = "";
+            }
+        } catch (Exception e) { /* ignore */ }
+        final android.widget.EditText input = new android.widget.EditText(this);
+        input.setHint("eyJh... (Cloudflare tunnel token)");
+        input.setText(existing);
+        new android.app.AlertDialog.Builder(this)
+            .setTitle("Cloudflare Tunnel")
+            .setMessage("Plak je tunnel-token (Cloudflare Zero Trust → Networks → Tunnels) voor een vast eigen domein. Leeg laten = tijdelijke trycloudflare.com-URL.")
+            .setView(input)
+            .setPositiveButton("Opslaan", (d, w) -> {
+                try {
+                    String tok = input.getText().toString().trim();
+                    if (tok.isEmpty()) {
+                        tokenFile.delete();
+                        android.widget.Toast.makeText(this, "Token gewist. Herstart de app voor een trycloudflare-URL.", android.widget.Toast.LENGTH_LONG).show();
+                    } else {
+                        java.io.FileWriter fw = new java.io.FileWriter(tokenFile, false);
+                        fw.write(tok + "\n");
+                        fw.close();
+                        android.widget.Toast.makeText(this, "Token opgeslagen. Herstart de app om de tunnel te starten.", android.widget.Toast.LENGTH_LONG).show();
+                    }
+                } catch (Exception e) {
+                    android.widget.Toast.makeText(this, "Opslaan mislukt: " + e.getMessage(), android.widget.Toast.LENGTH_LONG).show();
+                }
+            })
+            .setNegativeButton("Annuleren", null)
+            .show();
+    }
+
+    private void setupKlonktWebView() {
+        ensureKlonktBootstrap();
+        android.webkit.WebView webView = findViewById(R.id.klonkt_webview);
+        if (webView != null) {
+            webView.getSettings().setJavaScriptEnabled(true);
+            webView.getSettings().setDomStorageEnabled(true);
+            webView.getSettings().setMediaPlaybackRequiresUserGesture(false);
+            final String kurl = "http://localhost:3020";
+            final android.os.Handler kh = new android.os.Handler(android.os.Looper.getMainLooper());
+            webView.setWebViewClient(new android.webkit.WebViewClient() {
+                @Override
+                public void onReceivedError(android.webkit.WebView view, int errorCode, String description, String failingUrl) {
+                    // Only react when the MAIN page fails (ignore a missing subresource on a
+                    // working page), and never leave the raw browser error page standing:
+                    // always swap back to the splash, then retry until the server answers.
+                    if (failingUrl != null && !failingUrl.equals(kurl) && !failingUrl.equals(kurl + "/")) return;
+                    view.loadDataWithBaseURL(null, KLONKT_SPLASH, "text/html", "utf-8", null);
+                    kh.postDelayed(new Runnable() { public void run() { view.loadUrl(kurl); } }, 4000);
+                }
+            });
+            webView.loadDataWithBaseURL(null, KLONKT_SPLASH, "text/html", "utf-8", null);
+            kh.postDelayed(new Runnable() { public void run() { webView.loadUrl(kurl); } }, 2500);
+            
+            View tokenBtn = findViewById(R.id.klonkt_token_btn);
+            if (tokenBtn != null) tokenBtn.setOnClickListener(v -> showKlonktTokenDialog());
+
+            View toggleBtn = findViewById(R.id.toggle_view_btn);
+            if (toggleBtn != null) {
+                toggleBtn.setOnClickListener(v -> {
+                    if (webView.getVisibility() == View.VISIBLE) {
+                        webView.setVisibility(View.GONE);
+                    } else {
+                        webView.setVisibility(View.VISIBLE);
+                        webView.loadUrl(kurl);
+                    }
+                });
+            }
+        }
+    }
 
