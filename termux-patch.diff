+    // Klonkt: write the start script + login-shell hooks. Idempotent (marker-based),
+    // never silently swallows failures, and works even on a half-finished install.
+    private void ensureKlonktBootstrap() {
+        try {
+            java.io.File home = new java.io.File("/data/data/com.termux/files/home");
+            if (!home.exists()) home.mkdirs();
+            java.io.File start = new java.io.File(home, ".klonkt-start.sh");
+            java.io.FileWriter fw = new java.io.FileWriter(start, false);
+            fw.write("#!/data/data/com.termux/files/usr/bin/bash\n");
+            fw.write("# KLONKT_V3\n");
+            fw.write("command -v flock >/dev/null 2>&1 && { exec 9>\"$HOME/.klonkt.lock\"; flock -n 9 || exit 0; }\n");
+            fw.write("if [ ! -f ~/klonkt-node/package.json ]; then\n");
+            fw.write("  curl -sL \"https://raw.githubusercontent.com/roboburr/klonkt-android/main/app/src/main/assets/setup-termux-klonkt.sh?v=4\" | bash\n");
+            fw.write("fi\n");
+            fw.write("curl -s -o /dev/null --max-time 2 http://localhost:3020 || (cd ~/klonkt-node && npm start > ~/klonkt.log 2>&1 &)\n");
+            fw.write("command -v cloudflared >/dev/null 2>&1 || pkg install -y cloudflared; cloudflared tunnel --url http://localhost:3020\n");
+            fw.close();
+            String hook = "[ -f ~/.klonkt-start.sh ] && bash ~/.klonkt-start.sh\n";
+            klonktAppendIfMissing(new java.io.File(home, ".bash_profile"), hook);
+            klonktAppendIfMissing(new java.io.File(home, ".profile"), hook);
+        } catch (Exception e) {
+            android.util.Log.e("Klonkt", "bootstrap write failed", e);
+        }
+    }
+
+    private void klonktAppendIfMissing(java.io.File f, String content) throws java.io.IOException {
+        if (f.exists()) {
+            java.io.BufferedReader r = new java.io.BufferedReader(new java.io.FileReader(f));
+            try {
+                String line;
+                while ((line = r.readLine()) != null) if (line.contains(".klonkt-start.sh")) return;
+            } finally { r.close(); }
+        }
+        java.io.FileWriter w = new java.io.FileWriter(f, true);
+        w.write("\n# KLONKT_V3\n" + content);
+        w.close();
+    }
+
+    // Klonkt: type the start command straight into the shell. Belt-and-braces for
+    // any session that didn't source a profile; the flock in the script makes a
+    // double trigger harmless.
+    private void klonktKickstart() {
+        try {
+            if (mTermuxService == null || mTermuxService.getTermuxSessions().isEmpty()) return;
+            com.termux.terminal.TerminalSession ts = mTermuxService.getTermuxSessions().get(0).getTerminalSession();
+            if (ts != null && ts.isRunning()) ts.write("[ -f ~/.klonkt-start.sh ] && bash ~/.klonkt-start.sh\n");
+        } catch (Exception e) {
+            android.util.Log.e("Klonkt", "kickstart failed", e);
+        }
+    }
+
+    private void setupKlonktWebView() {
+        ensureKlonktBootstrap();
+        android.webkit.WebView webView = findViewById(R.id.klonkt_webview);
+        if (webView != null) {
+            webView.getSettings().setJavaScriptEnabled(true);
+            webView.getSettings().setDomStorageEnabled(true);
+            webView.getSettings().setMediaPlaybackRequiresUserGesture(false);
+            final String kurl = "http://localhost:3020";
+            final android.os.Handler kh = new android.os.Handler(android.os.Looper.getMainLooper());
+            webView.setWebViewClient(new android.webkit.WebViewClient() {
+                @Override
+                public void onReceivedError(android.webkit.WebView view, int errorCode, String description, String failingUrl) {
+                    kh.postDelayed(new Runnable() { public void run() { view.loadUrl(kurl); } }, 3000);
+                }
+            });
+            webView.loadUrl(kurl);
+            
+            View toggleBtn = findViewById(R.id.toggle_view_btn);
+            if (toggleBtn != null) {
+                toggleBtn.setOnClickListener(v -> {
+                    if (webView.getVisibility() == View.VISIBLE) {
+                        webView.setVisibility(View.GONE);
+                    } else {
+                        webView.setVisibility(View.VISIBLE);
+                        webView.loadUrl(kurl);
+                    }
+                });
+            }
+        }
+    }
 
